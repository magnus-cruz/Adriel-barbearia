      "dependsOn": [
        "Barbearia: Backend API",
        "Barbearia: Frontend estatico"
      ],
      "dependsOrder": "parallel",
      "problemMatcher": []
    },
    {
      "label": "Barbearia: Abrir frontend",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\.vscode\\scripts\\open-frontend.ps1"

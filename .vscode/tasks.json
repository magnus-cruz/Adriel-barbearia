{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Barbearia: Backend API",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\.vscode\\scripts\\start-backend.ps1"
      ],
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "Barbearia: Frontend estatico",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
